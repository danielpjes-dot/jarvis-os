[Unit]
Description=JARVIS voice capture (wake word mode) — optional, needs sounddevice
PartOf=jarvis.target
After=jarvis-react.service

[Service]
WorkingDirectory=/mnt/e/coding/jarvis-os
EnvironmentFile=-/mnt/e/coding/jarvis-os/.env
Environment=PYTHONUNBUFFERED=1
Environment=CUDA_VISIBLE_DEVICES=
ExecStart=/usr/bin/python3 -u /mnt/e/coding/jarvis-os/scripts/voice_capture.py --wake
Restart=on-failure
RestartSec=10
StartLimitIntervalSec=120
StartLimitBurst=3

[Install]
WantedBy=jarvis.target
